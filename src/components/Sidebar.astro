---
import type { Ressurs } from '@lib/types';

interface Props {
  relatert?: string[];
  emne: string;
  uke?: number[];
  ressursar?: Ressurs[];
  oppgaaver?: string[];
}
const { relatert = [], emne, uke = [], ressursar = [], oppgaaver = [] } = Astro.props;
const base = import.meta.env.BASE_URL;

const ukeStr = uke.length > 1 ? `Uke ${uke[0]}–${uke[uke.length - 1]}` : `Uke ${uke[0]}`;

const ressursIkon: Record<string, string> = {
  lenke: '🔗', video: '🎬', notat: '📄', oppgave: '✏️',
};
---
<aside style="padding:24px 22px;" aria-label="Sidepanel">

  {relatert.length > 0 && (
    <div style="margin-bottom:24px;">
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);margin-bottom:10px;">Relaterte emner</div>
      {relatert.map(slug => (
        <a href={`${base}/${emne}/${slug}`} style="display:block;font-size:13px;color:var(--accent);text-decoration:none;padding:6px 0;border-bottom:1px solid var(--border);transition:color .15s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--accent)'">
          {slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}
        </a>
      ))}
    </div>
  )}

  {uke.length > 0 && (
    <div style="margin-bottom:24px;">
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);margin-bottom:10px;">I årsplan</div>
      <a href={`${base}/`} style="display:inline-block;font-size:12px;background:var(--net-bg);color:var(--net);border:1px solid color-mix(in srgb, var(--net) 25%, transparent);padding:3px 10px;border-radius:6px;text-decoration:none;">
        {ukeStr} →
      </a>
    </div>
  )}

  {ressursar.length > 0 && (
    <div style="margin-bottom:24px;">
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);margin-bottom:10px;">Ressurser</div>
      {ressursar.map(r => (
        <a
          href={r.url ?? '#'}
          target={r.url ? '_blank' : undefined}
          rel={r.url ? 'noopener noreferrer' : undefined}
          style="display:block;font-size:13px;color:var(--accent);text-decoration:none;padding:6px 0;border-bottom:1px solid var(--border);"
        >
          {ressursIkon[r.type] ?? '📄'} {r.tittel}
          {r.lengde && <span style="color:var(--text3);font-size:11px;"> ({r.lengde})</span>}
        </a>
      ))}
    </div>
  )}

  {oppgaaver.length > 0 && (
    <div>
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);margin-bottom:10px;">Oppgaver</div>
      {oppgaaver.map(o => (
        <div style="font-size:13px;color:var(--text2);padding:6px 0;border-bottom:1px solid var(--border);line-height:1.4;">✏️ {o}</div>
      ))}
    </div>
  )}

</aside>
