---
---
<div
  role="toolbar"
  aria-label="Opplesing"
  style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;padding:11px 32px;background:var(--bg3);border-bottom:1px solid var(--border);font-size:13px;"
>
  <span aria-hidden="true">🔊</span>
  <button id="ttsPlay" class="tts-btn" aria-label="Les opp innholdet">▶ Les opp</button>
  <button id="ttsStop" class="tts-btn" aria-label="Stopp opplesing">⏹ Stopp</button>
  <div style="margin-left:auto;display:flex;align-items:center;gap:8px;color:var(--text2);">
    <label for="ttsRate">Hastighet:</label>
    <select id="ttsRate" style="background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:4px 8px;font-size:12px;color:var(--text);font-family:inherit;cursor:pointer;">
      <option value="0.8">Sakte</option>
      <option value="1" selected>Normal</option>
      <option value="1.3">Rask</option>
      <option value="1.6">Veldig rask</option>
    </select>
    <span style="font-size:11px;color:var(--text3);">Innebygd i nettleseren</span>
    <span style="font-size:11px;color:var(--text3);margin-left:6px;border-left:1px solid var(--border);padding-left:10px;">Tips: Marker tekst for å lese kun utvalget. ellers leses hele siden.</span>
  </div>
</div>

<style>
  .tts-btn {
    display: inline-flex; align-items: center; gap: 7px;
    background: var(--surface2); border: 1px solid var(--border2);
    border-radius: 8px; padding: 6px 14px; font-size: 13px;
    color: var(--text); cursor: pointer; font-family: inherit;
    transition: background .15s, border-color .15s, color .15s;
  }
  .tts-btn:hover { background: var(--bg2); border-color: var(--accent); color: var(--accent); }
  .tts-btn.playing { border-color: var(--accent); color: var(--accent); }
</style>

<script>
  let playing = false;
  let rate = 1;
  const playBtn = document.getElementById('ttsPlay')!;
  const stopBtn = document.getElementById('ttsStop')!;
  const rateSelect = document.getElementById('ttsRate') as HTMLSelectElement;

  rateSelect.addEventListener('change', () => { rate = parseFloat(rateSelect.value); });

  playBtn.addEventListener('click', () => {
    if (!window.speechSynthesis) return;
    if (playing) {
      speechSynthesis.pause();
      playing = false;
      playBtn.textContent = '▶ Les opp';
      playBtn.classList.remove('playing');
      return;
    }
    
    // Check if user has selected text
    const selection = window.getSelection();
    let textToRead = '';
    
    if (selection && selection.toString().trim() !== '') {
      textToRead = selection.toString();
    } else {
      const content = document.getElementById('ttsContent');
      if (!content) return;
      textToRead = content.innerText;
    }

    const utt = new SpeechSynthesisUtterance(textToRead);
    utt.lang = 'nb-NO'; utt.rate = rate;
    const voices = speechSynthesis.getVoices();
    const norVoice = voices.find(v => v.lang.startsWith('nb') || v.lang.startsWith('no'));
    if (norVoice) utt.voice = norVoice;
    utt.onstart = () => { playing = true; playBtn.textContent = '⏸ Pause'; playBtn.classList.add('playing'); };
    utt.onend = utt.onerror = () => { playing = false; playBtn.textContent = '▶ Les opp'; playBtn.classList.remove('playing'); };
    speechSynthesis.speak(utt);
  });

  stopBtn.addEventListener('click', () => {
    speechSynthesis.cancel();
    playing = false;
    playBtn.textContent = '▶ Les opp';
    playBtn.classList.remove('playing');
  });

  if (window.speechSynthesis) speechSynthesis.getVoices();
</script>
