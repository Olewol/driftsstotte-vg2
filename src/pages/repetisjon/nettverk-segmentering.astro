</tr>
<tr>
<td>20</td>
<td>Produksjon</td>
<td>192.168.20.0/24</td>
<td>Maskiner og utstyr</td>
<td>Kun nødvendig trafikk</td>
</tr>
<tr>
<td>30</td>
<td>Gjest</td>
<td>192.168.30.0/24</td>
<td>Besøkende</td>
<td>Kun internett</td>
</tr>
<tr>
