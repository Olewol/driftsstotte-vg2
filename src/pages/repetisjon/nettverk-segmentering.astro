</tr></thead><tbody>
<tr>
<td>IPsec</td>
<td>Bransjestandard, svært sikker</td>
<td>Kompleks konfigurasjon</td>
</tr>
<tr>
<td>OpenVPN</td>
<td>Fleksibel, kryssplattform</td>
<td>Lavere hastighet enn WireGuard</td>
</tr>
<tr>
<td>WireGuard</td>
<td>Moderne, rask, enkel</td>
