---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { slugify } from '@lib/slugify';

export async function getStaticPaths() {
  const notes = await getCollection('emner', e => e.data.public !== false);
  return notes.map(note => {
    const parts = note.id.split('/'); // e.g. "nettverk/tcp-ip-modellen.md"
    const emne = parts[0];
    const slug = slugify(parts[1].replace(/\.md$/, ''));
    return { params: { emne, slug }, props: { note } };
  });
}

const { note } = Astro.props;
const { Content } = await render(note);
const { title, emne, uke, kompetansemaal, relatert, ressursar, oppgaaver, notebooklm, flashcards, podcast, video, quiz, infographic } = note.data;
---
<ContentLayout
  title={title}
  emne={emne}
  uke={uke}
  kompetansemaal={kompetansemaal}
  relatert={relatert}
  ressursar={ressursar}
  oppgaaver={oppgaaver}
  notebooklm={notebooklm}
  flashcards={flashcards}
  podcast={podcast}
  video={video}
  quiz={quiz}
  infographic={infographic}
>
  <Content />
</ContentLayout>
