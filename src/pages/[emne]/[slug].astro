---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { slugify } from '@lib/slugify';

export async function getStaticPaths() {
  const notes = await getCollection('emner', e => e.data.public !== false);
  return notes.map(note => {
    const parts = note.id.split('/'); // e.g. "nettverk/tcp-ip-modellen.md"
    const emne = parts[0];
    const slug = slugify(parts[1].replace(/\.mdx?$/, ''));
    return { params: { emne, slug }, props: { note } };
  });
}

const { note } = Astro.props;
const { Content } = await render(note);
const { title, emne, uke, kompetansemaal, relatert, ressursar, oppgaaver, notebooklm, flashcards, podcast, video, quiz, infographic } = note.data;
const optionalProps = { notebooklm, flashcards, podcast, video, quiz, infographic };
// Coerce null to undefined for optional ContentLayout props
const clean = Object.fromEntries(
  Object.entries(optionalProps).map(([k, v]) => [k, v === null ? undefined : v])
);
const pageLang = note.id.endsWith('-en.md') ? 'en' : 'no';
const slug = note.id.split('/').pop()!.replace(/\.mdx?$/, '');
---
<ContentLayout
  title={title}
  emne={emne}
  uke={uke}
  kompetansemaal={kompetansemaal}
  relatert={relatert}
  ressursar={ressursar}
  oppgaaver={oppgaaver}
  notebooklm={clean.notebooklm}
  flashcards={clean.flashcards}
  podcast={clean.podcast}
  video={clean.video}
  quiz={clean.quiz}
  infographic={clean.infographic}
  language={pageLang}
  flashcardSlug={slug}
>
  <Content />
</ContentLayout>
