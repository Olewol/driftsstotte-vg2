---
import BaseLayout from './BaseLayout.astro';
const { title, description, prev, next, prevLabel, nextLabel } = Astro.props;
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;

const topics = [
  'brukeradministrasjon', 'infrastruktur-maskinvare', 'nettverk-segmentering',
  'nettverkssikkerhet', 'servermodeller-virtualisering', 'backup-gjenoppretting',
  'dokumentasjon-planlegging', 'nettverksprotokoller', 'sikkerhet-driftsprinsipper',
];
const topicIndex = topics.findIndex(t => path.includes(t)) + 1;
const totalTopics = topics.length;
const topicSlug = topics[topicIndex - 1] || '';
---

<BaseLayout title={title} description={description} lang="no">
  <article class="repetisjon-article">

    <!-- Breadcrumb + progress -->
    <div class="rep-header">
      <div class="rep-breadcrumb">
        <a href={`${base}/repetisjon`}>Forberedelse</a>
        <span>/</span>
        <span>{title}</span>
      </div>
      <div class="rep-dots" aria-label="Tema {topicIndex} av {totalTopics}">
        <div class="rep-dot-row">
          {Array.from({length: totalTopics}, (_, i) => (
            <div class={`rep-dot ${i < topicIndex ? 'rep-dot--done' : ''} ${i === topicIndex - 1 ? 'rep-dot--active' : ''}`}></div>
          ))}
        </div>
        <span class="rep-dots-label">{topicIndex}/{totalTopics}</span>
      </div>
    </div>

    <!-- Progress bar -->
    <div class="rep-progress-bar">
      <div class="rep-progress-fill" style="width:${(topicIndex / totalTopics) * 100}%"></div>
    </div>

    <!-- Header -->
    <div class="rep-hero">
      <div class="rep-hero-badge">
        <span class="rep-hero-check" id="theme-check" data-slug={topicSlug} onclick="toggleCompletion(this)">○</span>
        Tema {topicIndex} av {totalTopics}
      </div>
      <h1 class="rep-hero-title">{title}</h1>
      {description && <p class="rep-hero-desc">{description}</p>}
    </div>

    <!-- Desktop: sidebar + content grid -->
    <div class="rep-layout">
      <!-- TOC Sidebar -->
      <nav class="rep-toc" aria-label="På denne siden">
        <div class="rep-toc-title">På denne siden</div>
        <ul id="toc-list" class="rep-toc-list"></ul>
      </nav>

      <!-- Content -->
      <div class="rep-prose">
        <slot />
      </div>
    </div>

    <!-- Bottom nav -->
    <div class="rep-bottom-nav">
      {prev ? (
        <a href={`${base}/repetisjon/${prev}`} class="rep-nav-link rep-nav-link--prev">
          <div class="rep-nav-label">← Forrige tema</div>
          <div class="rep-nav-title">{prevLabel || prev}</div>
        </a>
      ) : <div style="flex:1;"></div>}
      {next ? (
        <a href={`${base}/repetisjon/${next}`} class="rep-nav-link rep-nav-link--next">
          <div class="rep-nav-label">Neste tema →</div>
          <div class="rep-nav-title">{nextLabel || next}</div>
        </a>
      ) : <div style="flex:1;"></div>}
    </div>

    <div class="rep-back-link">
      <a href={`${base}/repetisjon`}>← Tilbake til oversikten</a>
    </div>

  </article>

  <!-- Scroll to top -->
  <button id="scroll-top" class="rep-scroll-top" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="Til toppen">↑</button>
</BaseLayout>

<style>
  /* ---- Layout ---- */
  .repetisjon-article {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 32px 80px;
  }

  /* Header row */
  .rep-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 28px 0 4px;
    flex-wrap: wrap;
  }
  .rep-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text3);
  }
  .rep-breadcrumb a { color: var(--accent); text-decoration: none; }

  /* Dots */
  .rep-dots { display: flex; align-items: center; gap: 10px; }
  .rep-dot-row { display: flex; gap: 4px; }
  .rep-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--border);
    transition: background .3s, transform .2s;
  }
  .rep-dot--done { background: var(--accent); }
  .rep-dot--active { transform: scale(1.4); background: var(--accent); box-shadow: 0 0 6px rgba(79,140,255,.4); }
  .rep-dots-label { font-size: 11px; color: var(--text3); font-weight: 600; }

  /* Progress bar */
  .rep-progress-bar {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    margin: 6px 0 0;
  }
  .rep-progress-fill {
    height: 100%;
    background: var(--grad);
    border-radius: 2px;
    transition: width .5s ease;
  }

  /* Hero */
  .rep-hero {
    padding: 16px 0 24px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 28px;
  }
  .rep-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(79,140,255,.13);
    color: var(--accent);
    border: 1px solid rgba(79,140,255,.3);
    font-size: 12px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 12px;
  }
  .rep-hero-check {
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    transition: transform .15s;
    user-select: none;
  }
  .rep-hero-check:hover { transform: scale(1.3); }
  .rep-hero-check.done { color: #10b981; }
  .rep-hero-title {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -.025em;
    margin-bottom: 8px;
    color: var(--text);
  }
  .rep-hero-desc {
    font-size: 15px;
    color: var(--text2);
    line-height: 1.65;
  }

  /* ---- Desktop grid: sidebar + content ---- */
  .rep-layout {
    display: block;
  }

  /* TOC */
  .rep-toc {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 32px;
  }
  .rep-toc-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--text3);
    margin-bottom: 10px;
  }
  .rep-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .rep-toc-list li { font-size: 13px; }
  .rep-toc-list a {
    color: var(--accent);
    text-decoration: none;
    padding: 2px 0;
    display: inline-block;
    transition: color .15s;
  }
  .rep-toc-list a:hover { color: var(--text); }
  .rep-toc-list .toc-h3 {
    padding-left: 16px;
    font-size: 12px;
    position: relative;
  }
  .rep-toc-list .toc-h3::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--text3);
    opacity: .5;
  }

  /* ---- Prose content ---- */
  .rep-prose {
    font-size: 16px;
    line-height: 1.85;
    color: var(--text2);
  }
  .rep-prose p { margin-bottom: 1.2rem; }

  .rep-prose h2 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text);
    margin: 2.2rem 0 0.8rem;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
    scroll-margin-top: 80px;
  }
  .rep-prose h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    margin: 1.6rem 0 0.5rem;
  }
  .rep-prose h4 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text2);
    margin: 1.2rem 0 0.3rem;
  }
  .rep-prose a { color: var(--accent); border-bottom: 1px solid color-mix(in srgb, var(--accent) 40%, transparent); }
  .rep-prose a:hover { border-color: var(--accent); text-decoration: none; }
  .rep-prose strong { color: var(--text); }
  .rep-prose ul, .rep-prose ol {
    margin: 0.6rem 0 1rem;
    padding-left: 1.5rem;
  }
  .rep-prose li { margin-bottom: 0.4rem; line-height: 1.7; }
  .rep-prose code {
    background: var(--bg3);
    padding: 2px 7px;
    border-radius: 5px;
    font-size: 0.875em;
    color: #e2e8f0;
  }
  .rep-prose pre {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.2rem 1.4rem;
    overflow-x: auto;
    margin: 1.2rem 0;
    font-size: 14px;
    line-height: 1.6;
  }
  .rep-prose pre code { background: none; padding: 0; }

  /* Tables */
  .rep-prose table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 14px;
    margin: 1.2rem 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .rep-prose th {
    background: linear-gradient(135deg, var(--bg3) 0%, rgba(79,140,255,.06) 100%);
    color: var(--text);
    padding: 11px 14px;
    text-align: left;
    border: none;
    border-bottom: 1px solid var(--border);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .05em;
  }
  .rep-prose td {
    padding: 10px 14px;
    border: none;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    vertical-align: top;
  }
  .rep-prose tr:last-child td { border-bottom: none; }
  .rep-prose tr:nth-child(even) td { background: var(--surface); }
  .rep-prose tr:hover td { background: var(--surface2); }

  /* ---- Callout boxes ---- */

  /* Eksamen-callout */
  .eksamen-callout {
    background: linear-gradient(135deg, rgba(249,115,22,.08) 0%, rgba(236,72,153,.06) 100%);
    border: 1px solid rgba(249,115,22,.25);
    border-radius: 12px;
    padding: 20px 24px;
    margin: 1.8rem 0;
    transition: border-color .2s;
  }
  .eksamen-callout:hover { border-color: rgba(249,115,22,.4); }
  .eksamen-callout-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: #f97316;
    margin-bottom: 10px;
  }
  .eksamen-callout p { margin-bottom: 0.5rem !important; }
  .eksamen-callout p:last-child { margin-bottom: 0 !important; }
  .eksamen-callout ul { margin: 0.4rem 0 0 0; }
  .eksamen-callout li { margin-bottom: 0.3rem; }

  /* Tips-callout */
  .tips-callout {
    background: linear-gradient(135deg, rgba(16,185,129,.07) 0%, rgba(79,140,255,.05) 100%);
    border: 1px solid rgba(16,185,129,.2);
    border-radius: 12px;
    padding: 18px 22px;
    margin: 1.5rem 0;
  }
  .tips-callout:hover { border-color: rgba(16,185,129,.35); }
  .tips-callout-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: #10b981;
    margin-bottom: 10px;
  }
  .tips-callout p { margin-bottom: 0.5rem !important; }
  .tips-callout p:last-child { margin-bottom: 0 !important; }
  .tips-callout ul { margin: 0.4rem 0 0 0; }
  .tips-callout li { margin-bottom: 0.3rem; }

  /* Hvorfor-callout */
  .hvorfor-callout {
    background: linear-gradient(135deg, rgba(79,140,255,.07) 0%, rgba(6,214,199,.05) 100%);
    border: 1px solid rgba(79,140,255,.2);
    border-radius: 12px;
    padding: 18px 22px;
    margin: 1.5rem 0;
  }
  .hvorfor-callout:hover { border-color: rgba(79,140,255,.35); }
  .hvorfor-callout-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .hvorfor-callout p { margin-bottom: 0.5rem !important; }
  .hvorfor-callout p:last-child { margin-bottom: 0 !important; }
  .hvorfor-callout strong { color: var(--text); }

  /* ---- Key concepts box ---- */
  .nokkelbegreper {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px 24px;
    margin: 1.8rem 0;
  }
  .nokkelbegreper-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--text3);
    margin-bottom: 14px;
  }
  .nokkelbegreper-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .nokkelbegrep-item {
    background: var(--bg3);
    border-radius: 8px;
    padding: 12px 14px;
    border: 1px solid var(--border);
  }
  .nokkelbegrep-item strong {
    display: block;
    font-size: 13px;
    color: var(--accent);
    margin-bottom: 4px;
  }
  .nokkelbegrep-item span {
    font-size: 13px;
    color: var(--text2);
    line-height: 1.5;
  }

  /* ---- Sjekk om du kan dette ---- */
  .sjekk-sporsmal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px 24px;
    margin: 1.8rem 0;
  }
  .sjekk-sporsmal-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: #a855f7;
    margin-bottom: 14px;
  }
  .sjekk-q {
    padding: 12px 14px;
    background: var(--bg3);
    border-radius: 8px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: background .15s;
    border: 1px solid transparent;
  }
  .sjekk-q:hover { background: var(--surface2); border-color: var(--border); }
  .sjekk-q-question {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }
  .sjekk-q-answer {
    font-size: 14px;
    color: var(--text2);
    line-height: 1.6;
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
    display: none;
  }
  .sjekk-q.open .sjekk-q-answer { display: block; }

  /* ---- Definition list style ---- */
  .def-term { font-weight: 600; color: var(--text); }
  .def-desc { color: var(--text2); margin-bottom: 0.6rem; }

  /* ---- Comparison table alt style ---- */
  .compare-box {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin: 1.2rem 0;
  }
  .compare-header {
    background: var(--bg3);
    padding: 10px 14px;
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--text);
  }
  .compare-cell {
    background: var(--surface);
    padding: 10px 14px;
    font-size: 14px;
    color: var(--text2);
  }

  /* ---- Bottom nav ---- */
  .rep-bottom-nav {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .rep-nav-link {
    flex: 1;
    padding: 16px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: all .18s;
    color: var(--text);
  }
  .rep-nav-link:hover {
    background: var(--surface2);
    border-color: var(--border2);
    transform: translateY(-2px);
  }
  .rep-nav-link--next { text-align: right; }
  .rep-nav-label {
    font-size: 11px;
    color: var(--text3);
    margin-bottom: 4px;
  }
  .rep-nav-title {
    font-size: 14px;
    font-weight: 600;
  }

  /* Back link */
  .rep-back-link {
    text-align: center;
    margin-top: 32px;
  }
  .rep-back-link a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text3);
    text-decoration: none;
    transition: color .15s;
  }
  .rep-back-link a:hover { color: var(--accent); }

  /* ---- Scroll to top ---- */
  .rep-scroll-top {
    position: fixed;
    bottom: 32px;
    right: 32px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text2);
    font-size: 20px;
    cursor: pointer;
    transition: all .2s;
    z-index: 100;
    opacity: 0;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rep-scroll-top.visible {
    opacity: 1;
    pointer-events: auto;
  }
  .rep-scroll-top:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 4px 16px rgba(79,140,255,.3);
  }

  /* ---- Desktop sticky sidebar ---- */
  @media (min-width: 1024px) {
    .repetisjon-article { max-width: 1120px; }
    .rep-layout {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 32px;
      align-items: start;
    }
    .rep-toc {
      position: sticky;
      top: 88px;
      margin-bottom: 0;
    }
    .rep-toc-list { max-height: calc(100vh - 180px); overflow-y: auto; }
  }

  @media (max-width: 768px) {
    .repetisjon-article { padding-left: 20px !important; padding-right: 20px !important; }
    .rep-prose { font-size: 15px; }
    .rep-prose table { font-size: 13px; }
    .nokkelbegreper-grid { grid-template-columns: 1fr; }
    .rep-scroll-top { bottom: 20px; right: 20px; width: 40px; height: 40px; font-size: 18px; }
  }
</style>

<script>
  // Global type declaration for custom window property
  declare global {
    interface Window {
      toggleCompletion: (el: HTMLElement) => void;
    }
  }
  // === TOC generation (h2 + h3) ===
  const toc = document.getElementById('toc-list');
  const prose = document.querySelector('.rep-prose');
  if (toc && prose) {
    const headings = prose.querySelectorAll('h2, h3');
    let h2count = 0;
    headings.forEach((h) => {
      if (!h.id) {
        h.id = h.textContent.toLowerCase().replace(/[^a-z0-9æøå]+/g, '-').replace(/^-|-$/g, '') || `section-${h2count}`;
      }
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent;
      if (h.tagName === 'H3') {
        a.classList.add('toc-h3');
        a.style.cssText = 'padding-left:16px;font-size:12px;color:var(--text2);';
      }
      a.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById(h.id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.pushState(null, '', `#${h.id}`);
      });
      li.appendChild(a);
      toc.appendChild(li);
    });
  }

  // === TOC scroll-spy (h2 only) ===
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const id = entry.target.id;
      if (!id) return;
      const link = toc?.querySelector(`a[href="#${id}"]`) as HTMLElement | null;
      if (!link) return;
      if (entry.isIntersecting) {
        link.style.color = 'var(--text)';
        link.style.fontWeight = '600';
      } else {
        link.style.color = 'var(--accent)';
        link.style.fontWeight = '400';
      }
    });
  }, { threshold: 0.2, rootMargin: '-80px 0px 0px 0px' });

  document.querySelectorAll('.rep-prose h2').forEach(h => observer.observe(h));

  // === Scroll-to-top visibility ===
  const scrollBtn = document.getElementById('scroll-top');
  let scrollTimer: ReturnType<typeof setTimeout> | null = null;
  if (scrollBtn) {
    window.addEventListener('scroll', () => {
      if (scrollTimer) return;
      scrollTimer = setTimeout(() => {
        scrollBtn.classList.toggle('visible', window.scrollY > 400);
        scrollTimer = null;
      }, 80);
    });
  }

  // === Completion toggling (localStorage) ===
  window.toggleCompletion = function(el: HTMLElement) {
    const slug = el.dataset.slug;
    if (!slug) return;
    const key = `rep-complete-${slug}`;
    const done = localStorage.getItem(key) === 'true';
    if (done) {
      localStorage.removeItem(key);
      el.textContent = '○';
      el.classList.remove('done');
    } else {
      localStorage.setItem(key, 'true');
      el.textContent = '●';
      el.classList.add('done');
    }
  };

  // Restore completion state on page load
  document.addEventListener('DOMContentLoaded', () => {
    const check = document.getElementById('theme-check');
    if (check) {
      const slug = check.dataset.slug;
      if (slug && localStorage.getItem(`rep-complete-${slug}`) === 'true') {
        check.textContent = '●';
        check.classList.add('done');
      }
    }
  });

  // === Sjekk-sporsmal toggle ===
  document.querySelectorAll('.sjekk-q').forEach(el => {
    el.addEventListener('click', () => el.classList.toggle('open'));
  });
</script>
