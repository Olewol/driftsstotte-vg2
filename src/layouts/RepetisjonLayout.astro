---
import BaseLayout from './BaseLayout.astro';
const { title, description, prev, next, prevLabel, nextLabel } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <article style="max-width:860px;margin:0 auto;padding:0 32px 80px;">

    <!-- Breadcrumb -->
    <div style="display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text3);padding:28px 0 4px;">
      <a href={`${base}/repetisjon`} style="color:var(--accent);text-decoration:none;">Forberedelse</a>
      <span>/</span>
      <span style="color:var(--text2);">{title}</span>
    </div>

    <!-- Header -->
    <div style="padding:16px 0 24px;border-bottom:1px solid var(--border);margin-bottom:28px;">
      <div style="display:inline-flex;align-items:center;gap:6px;background:rgba(236,72,153,.13);color:#ec4899;border:1px solid rgba(236,72,153,.3);font-size:12px;font-weight:600;padding:4px 12px;border-radius:20px;margin-bottom:12px;">
        Eksamensrepetisjon
      </div>
      <h1 style="font-size:30px;font-weight:800;letter-spacing:-.02em;margin-bottom:8px;color:var(--text);">{title}</h1>
      {description && <p style="font-size:15px;color:var(--text2);line-height:1.6;">{description}</p>}
    </div>

    <!-- Innholdsfortegnelse for siden -->
    <nav class="repetisjon-toc" aria-label="På denne siden" style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px 22px;margin-bottom:32px;">
      <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);margin-bottom:10px;">På denne siden</div>
      <ul id="toc-list" style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:4px;">
        <li style="font-size:13px;">↳ <a href="#kort-oppsummert" style="color:var(--accent);text-decoration:none;">Kort oppsummert</a></li>
        <li style="font-size:13px;">↳ <a href="#detaljer" style="color:var(--accent);text-decoration:none;">Detaljer</a></li>
        <li style="font-size:13px;">↳ <a href="#husk-til-eksamen" style="color:var(--accent);text-decoration:none;">Husk til eksamen</a></li>
      </ul>
    </nav>

    <!-- Content -->
    <div class="repetisjon-prose">
      <slot />
    </div>

    <!-- Bottom navigation -->
    <div style="display:flex;justify-content:space-between;gap:16px;margin-top:48px;padding-top:24px;border-top:1px solid var(--border);">
      {prev ? (
        <a href={`${base}/repetisjon/${prev}`} style="flex:1;padding:16px 20px;background:var(--surface);border:1px solid var(--border);border-radius:12px;text-decoration:none;transition:background .15s,border-color .15s;color:var(--text);" onmouseover="this.style.background='var(--surface2)';this.style.borderColor='var(--border2)'" onmouseout="this.style.background='var(--surface)';this.style.borderColor='var(--border)'">
          <div style="font-size:11px;color:var(--text3);margin-bottom:4px;">← Forrige</div>
          <div style="font-size:14px;font-weight:600;">{prevLabel || prev}</div>
        </a>
      ) : <div style="flex:1;"></div>}
      {next ? (
        <a href={`${base}/repetisjon/${next}`} style="flex:1;padding:16px 20px;background:var(--surface);border:1px solid var(--border);border-radius:12px;text-decoration:none;text-align:right;transition:background .15s,border-color .15s;color:var(--text);" onmouseover="this.style.background='var(--surface2)';this.style.borderColor='var(--border2)'" onmouseout="this.style.background='var(--surface)';this.style.borderColor='var(--border)'">
          <div style="font-size:11px;color:var(--text3);margin-bottom:4px;">Neste →</div>
          <div style="font-size:14px;font-weight:600;">{nextLabel || next}</div>
        </a>
      ) : <div style="flex:1;"></div>}
    </div>

    <div style="text-align:center;margin-top:32px;">
      <a href={`${base}/repetisjon`} style="display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--text3);text-decoration:none;transition:color .15s;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text3)'">
        ← Tilbake til oversikten
      </a>
    </div>

  </article>
</BaseLayout>

<style>
  .repetisjon-prose {
    font-size: 15px;
    line-height: 1.85;
    color: var(--text2);
  }
  .repetisjon-prose p { margin-bottom: 1.1rem; }
  .repetisjon-prose h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text);
    margin: 1.8rem 0 0.6rem;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }
  .repetisjon-prose h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin: 1.4rem 0 0.4rem;
  }
  .repetisjon-prose h4 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin: 1rem 0 0.3rem;
  }
  .repetisjon-prose a {
    color: var(--accent);
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .repetisjon-prose a:hover { border-color: var(--accent); text-decoration: none; }
  .repetisjon-prose strong { color: var(--text); }
  .repetisjon-prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
    margin: 1rem 0;
  }
  .repetisjon-prose th {
    background: var(--bg3);
    color: var(--text2);
    padding: 9px 12px;
    text-align: left;
    border: 1px solid var(--border);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
  }
  .repetisjon-prose td {
    padding: 9px 12px;
    border: 1px solid var(--border);
    color: var(--text);
  }
  .repetisjon-prose tr:nth-child(even) td { background: var(--surface); }
  .repetisjon-prose ul, .repetisjon-prose ol {
    margin: 0.6rem 0;
    padding-left: 1.5rem;
  }
  .repetisjon-prose li { margin-bottom: 0.3rem; }
  .repetisjon-prose code {
    background: var(--bg3);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.875em;
  }
  .repetisjon-prose pre {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    margin: 1rem 0;
  }
  .repetisjon-prose pre code { background: none; padding: 0; }

  /* Husk til eksamen - callout box */
  .eksamen-callout {
    background: linear-gradient(135deg, rgba(249,115,22,.1) 0%, rgba(236,72,153,.08) 100%);
    border-left: 4px solid #f97316;
    border-radius: 10px;
    padding: 18px 22px;
    margin: 1.5rem 0;
  }
  .eksamen-callout-title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: #f97316;
    margin-bottom: 6px;
  }
  .eksamen-callout p { margin-bottom: 0 !important; }
  .eksamen-callout ul { margin: 0.4rem 0 0 0; }

  @media (max-width: 768px) {
    article { padding-left: 20px !important; padding-right: 20px !important; }
  }
</style>

<script>
  // Auto-generate TOC from h2 headings in the content
  const toc = document.getElementById('toc-list');
  if (toc) {
    toc.innerHTML = '';
    const headings = document.querySelector('.repetisjon-prose')?.querySelectorAll('h2') || [];
    headings.forEach((h, i) => {
      if (!h.id) h.id = `section-${i}`;
      const li = document.createElement('li');
      li.style.cssText = 'font-size:13px;';
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent;
      a.style.cssText = 'color:var(--accent);text-decoration:none;';
      li.innerHTML = '↳ ';
      li.appendChild(a);
      toc.appendChild(li);
    });
  }
</script>
